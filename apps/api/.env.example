# ─────────────────────────────────────────────────────────────────
# apps/api — environment variables
# Copy to .env.local and fill in values. Never commit the real file.
# ─────────────────────────────────────────────────────────────────

# ── Auth (Clerk) ───────────────────────────────────────────────────
# Leave CLERK_SECRET_KEY unset for local dev — the API will use DevAuthProvider,
# which accepts any Bearer token as the user ID.
CLERK_SECRET_KEY=sk_test_...

# ── Local dev auth (only used when CLERK_SECRET_KEY is unset) ──────
# Fixed user identity. Must match DEV_AUTH_TOKEN in apps/web/.env.
DEV_USER_ID=dev-user
DEV_USER_EMAIL=dev@example.com

# ── User data database (Prisma / Cloud SQL Postgres) ──────────────
# When set, the API persists lift records, training maxes, and cycle
# dashboards to Postgres via Prisma. Falls back to in-memory when
# unset (default for local dev without a database).
#
# Row-Level Security (issue #511): RLS policies only constrain a NON-superuser,
# NON-BYPASSRLS role. In deployed environments (staging/prod), point this URL at the
# `lifting_app` role created by the 20260611000000_enable_rls migration so the
# defense-in-depth policies are actually enforced. Run `prisma migrate deploy` as the
# owner/superuser role (a separate connection string), not as `lifting_app`. Connecting
# as a superuser (as local dev and CI do) leaves RLS dormant — the app still works via
# the existing per-query userId scoping, which is also the instant-rollback path.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lifting_logbook

# ── System dispatch database ───────────────────────────────────────
# Production only — not needed for local dev.
# When set (and DATABASE_URL is unset), the API consults the user_data_source
# table to route each user to their configured adapter ('in-memory' or 'postgres').
# DATABASE_URL takes precedence over SYSTEM_DATABASE_URL when both are set.
# See infra/migrations/001_create_user_data_source.sql for schema.
SYSTEM_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lifting_logbook_system

# ── Per-user data database (SystemDb dispatch path only) ───────────
# Required when SYSTEM_DATABASE_URL is set and any user has
# adapter_type='postgres' in user_data_source. This is the shared
# Postgres instance for per-user lift data routed through SystemDb.
# Distinct from DATABASE_URL (the direct shared-DB / PrismaRepositoryFactory path).
USER_DATA_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lifting_logbook_user_data
