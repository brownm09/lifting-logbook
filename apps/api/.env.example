# ─────────────────────────────────────────────────────────────────
# apps/api — environment variables
# Copy to .env.local and fill in values. Never commit the real file.
# ─────────────────────────────────────────────────────────────────

# ── Auth (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...

# ── User data database (Prisma / Cloud SQL Postgres) ──────────────
# When set, the API persists lift records, training maxes, and cycle
# dashboards to Postgres via Prisma. Falls back to in-memory when
# unset (default for local dev without a database).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lifting_logbook

# ── System dispatch database ───────────────────────────────────────
# Optional. When set alongside DATABASE_URL=unset, the API consults
# the user_data_source table to route each user to their configured
# adapter (currently supports 'in-memory' and 'postgres').
# See infra/migrations/001_create_user_data_source.sql for schema.
SYSTEM_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/lifting_logbook_system
