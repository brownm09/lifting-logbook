generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["tracing"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LiftRecord {
  id         String   @id @default(cuid())
  userId     String
  program    String
  cycleNum   Int
  workoutNum Int
  date       DateTime
  lift       String
  setNum     Int
  weight     Float
  reps       Int
  notes      String   @default("")

  @@unique([userId, program, cycleNum, workoutNum, lift, setNum])
  @@index([userId, program, cycleNum])
  @@index([userId, program, cycleNum, workoutNum])
  @@map("lift_record")
}

model TrainingMax {
  id          String   @id @default(cuid())
  userId      String
  program     String
  lift        String
  weight      Float
  dateUpdated DateTime

  @@unique([userId, program, lift])
  @@index([userId, program])
  @@map("training_max")
}

model CycleDashboard {
  id                String   @id @default(cuid())
  userId            String
  program           String
  cycleUnit         String
  cycleNum          Int
  cycleDate         DateTime
  sheetName         String
  cycleStartWeekday String
  currentWeekType   String
  programType       String?

  @@unique([userId, program])
  @@index([userId, program])
  @@map("cycle_dashboard")
}

model TrainingMaxHistory {
  id        String   @id @default(cuid())
  userId    String
  program   String
  lift      String
  weight    Float
  reps      Int      @default(1)
  date      DateTime
  isPR      Boolean  @default(false)
  source    String
  goalMet   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, program])
  @@index([userId, program, lift])
  @@map("training_max_history")
}

model StrengthGoal {
  id        String   @id @default(cuid())
  userId    String
  program   String
  lift      String
  goalType  String   @default("relative")
  target    Float?
  unit      String
  ratio     Float?
  updatedAt DateTime @updatedAt

  @@unique([userId, program, lift])
  @@index([userId, program])
  @@map("strength_goal")
}

model WorkoutDateOverride {
  id         String   @id @default(cuid())
  userId     String
  program    String
  cycleNum   Int
  workoutNum Int
  newDate    DateTime
  createdAt  DateTime @default(now())

  @@unique([userId, program, cycleNum, workoutNum])
  @@index([userId, program, cycleNum])
  @@map("workout_date_override")
}

model WorkoutLiftOverride {
  id         String   @id @default(cuid())
  userId     String
  program    String
  cycleNum   Int
  workoutNum Int
  lift       String
  action     String
  replacedBy String?
  createdAt  DateTime @default(now())

  @@unique([userId, program, cycleNum, workoutNum, lift])
  @@index([userId, program, cycleNum, workoutNum])
  @@map("workout_lift_override")
}

model LiftMetadata {
  id            String   @id @default(uuid())
  userId        String
  lift          String
  muscleGroups  String[]
  substitutions String[]
  foundational  Boolean  @default(false)

  @@unique([userId, lift])
  @@index([userId])
  @@map("lift_metadata")
}

model UserSettings {
  userId          String  @id
  activeProgram   String?
  workoutSchedule Json?

  @@map("user_settings")
}

model CycleScheduledWorkout {
  id            String   @id @default(uuid())
  userId        String
  program       String
  cycleNum      Int
  workoutNum    Int
  weekNum       Int
  scheduledDate DateTime @db.Date

  @@unique([userId, program, cycleNum, workoutNum])
  @@index([userId, program, cycleNum])
  @@map("cycle_scheduled_workout")
}

model CustomProgram {
  id           String              @id @default(uuid())
  userId       String
  name         String
  description  String?
  baseTemplate String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  specs        CustomProgramSpec[]

  @@index([userId])
  @@map("custom_program")
}

model CustomProgramSpec {
  id             String        @id @default(uuid())
  programId      String
  week           Int
  offset         Int           @default(0)
  lift           String
  increment      Float
  order          Int
  sets           Int
  reps           Int
  amrap          Boolean       @default(false)
  warmUpPct      String
  wtDecrementPct Float
  activation     String
  weekType       String?
  program        CustomProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@map("custom_program_spec")
}
