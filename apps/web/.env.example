# Public config is injected at RUNTIME, not baked into the bundle at build time
# (#396 / ADR-028). These variables intentionally have NO `NEXT_PUBLIC_` prefix so
# Next.js does not inline them; the root layout reads them at request time.

# URL of the NestJS API server, reachable from the Next.js process (server-side only)
API_URL=http://localhost:3004

# URL reachable from the browser (injected into window.__PUBLIC_CONFIG__ at runtime)
PUBLIC_API_URL=http://localhost:3004

# Default lifting program identifier — used as the :program path param in all API calls.
# Local-dev override only: deployed environments do NOT set this and fall back to the code
# default ('5-3-1') in lib/active-program.ts (#396 / ADR-028).
DEFAULT_PROGRAM=5-3-1

# ── Local dev auth ────────────────────────────────────────────────────────────
# When CLERK_SECRET_KEY is unset, the API uses DevAuthProvider which accepts any
# Bearer token as the user ID. Set this to match DEV_USER_ID in apps/api/.env.
# It is surfaced to the browser via window.__PUBLIC_CONFIG__ only when set (never
# in deployed environments).
DEV_AUTH_TOKEN=dev-user

# ── Clerk auth ────────────────────────────────────────────────────────────────
# NEITHER Clerk key is needed for local dev-auth mode. When DEV_AUTH_TOKEN (above) is
# set, the root layout (app/layout.tsx) skips <ClerkProvider> entirely and middleware.ts
# bypasses clerkMiddleware(), so Clerk is fully inert — `next dev` boots with no Clerk key
# and ClerkJS never initializes in the browser (so there is no console noise). Leave both
# keys unset locally.
#
# For a REAL Clerk sign-in flow (or staging / production), unset DEV_AUTH_TOKEN (above) to
# switch into real-Clerk mode and set BOTH keys below from your Clerk dashboard
# (https://dashboard.clerk.com -> API Keys). No NEXT_PUBLIC_ prefix on the publishable key:
# the layout reads it at request time and passes it to <ClerkProvider>. Never commit a real
# secret key — .env / .env*.local are gitignored for this reason.
# CLERK_PUBLISHABLE_KEY=pk_test_...   # browser SDK key, passed to <ClerkProvider>
# CLERK_SECRET_KEY=sk_test_...        # server-side SDK secret

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# OTLP endpoint for trace export. Local dev: point to the otel-collector from
# issue #207's docker-compose stack. Grafana Cloud: set per ADR-018.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
