# Single source of truth for the otel-collector image (#795 / #788).
#
# The image is served from the per-environment Artifact Registry Docker Hub
# pull-through mirror (google_artifact_registry_repository.dockerhub_mirror,
# infra/terraform, #795) instead of Docker Hub directly, and pinned by immutable
# digest for reproducibility. The AR host/project prefix is per-environment
# (terraform output `otel_collector_mirror_repo`); this file pins the two parts
# that are identical across environments — the repository path within the mirror
# and the digest. deploy.yml sources this file and composes
#   <otel_mirror_repo>/${OTEL_COLLECTOR_IMAGE_REPO_PATH}@${OTEL_COLLECTOR_IMAGE_DIGEST}
# for both the Cloud Run sidecar (COLLECTOR_IMAGE, via scripts/inject-otel-sidecar.py)
# and the GKE chart (helm --set-string image.repository / image.digest).
#
# To bump the collector version: resolve the new manifest-list digest
#   crane digest otel/opentelemetry-collector-contrib:<tag>
#   (or: docker manifest inspect otel/opentelemetry-collector-contrib:<tag>)
# update the tag comment + digest here, and mirror the tag in
# infra/kubernetes/charts/otel-collector/Chart.yaml (appVersion) and values.yaml (image.tag).

# otel/opentelemetry-collector-contrib:0.104.0
OTEL_COLLECTOR_IMAGE_REPO_PATH=otel/opentelemetry-collector-contrib
OTEL_COLLECTOR_IMAGE_DIGEST=sha256:e07e325e303e86f4a87a617491e921b579a92da6d404007394757ac910bf9587
