# Grafana Cloud Mimir query credentials — copy to `.mimir-credentials` and fill in.
#
#   cp scripts/observability/.mimir-credentials.example scripts/observability/.mimir-credentials
#
# `.mimir-credentials` is gitignored. NEVER put real tokens in this `.example`
# file or anywhere else that is committed.
#
# Where to find each value (Grafana Cloud portal -> your stack):
#   MIMIR_ADDRESS   Prometheus -> "Sending metrics": the query/remote-write URL
#                   base. The auth (user/key) is shared with `mimirtool rules
#                   load`, but the URL base may differ between the two: mimirtool
#                   takes the instance base and appends its own path, while the
#                   query API this script hits is at "${MIMIR_ADDRESS}/api/v1/query".
#                   If that 404s, set MIMIR_QUERY_URL below to the exact endpoint.
#   MIMIR_API_USER  the numeric instance / user ID shown next to that URL.
#   MIMIR_API_KEY   an Access Policy token scoped to `metrics:read`
#                   (Account -> Access Policies -> create a token).
#
# Optional:
#   MIMIR_QUERY_URL  the FULL query endpoint, used verbatim if set. Provide it
#                    when "${MIMIR_ADDRESS}/api/v1/query" is not correct for your
#                    stack: copy the Prometheus data source URL from Grafana and
#                    append /api/v1/query.
#   MIMIR_TENANT_ID  X-Scope-OrgID header value — self-hosted Mimir only. Leave
#                    unset for Grafana Cloud (the basic-auth user carries tenancy).

export MIMIR_ADDRESS="https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom"
export MIMIR_API_USER="123456"
export MIMIR_API_KEY="glc_REPLACE_WITH_A_metrics_read_TOKEN"
# export MIMIR_QUERY_URL="https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/api/v1/query"
# export MIMIR_TENANT_ID=""
