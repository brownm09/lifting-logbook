# Grafana Cloud Tempo query credentials — copy to `.tempo-credentials` and fill in.
#
#   cp scripts/observability/.tempo-credentials.example scripts/observability/.tempo-credentials
#
# `.tempo-credentials` is gitignored. NEVER put real tokens in this `.example`
# file or anywhere else that is committed.
#
# Scope: READ-ONLY trace queries. The token below must be an Access Policy token
# scoped to `traces:read` ONLY — the tempo-query.sh helper issues nothing but HTTP
# GETs against Tempo's read endpoints, so a write/ingest scope is never required.
#
# This file supplies credentials for one or both targets. tempo-query-env.sh picks
# between them with TEMPO_TARGET (default `staging`):
#     source scripts/observability/tempo-query-env.sh               # staging
#     TEMPO_TARGET=prod source scripts/observability/tempo-query-env.sh
#
# Where to find each value (Grafana Cloud portal -> your stack -> Tempo -> "Sending
# Data", or the Tempo data source details page):
#   *_ADDRESS   The Tempo QUERY base URL — the base under which the read API lives so
#               that "${ADDRESS}/api/search" resolves. Depending on your stack this is
#               either
#                   https://tempo-prod-XX-prod-REGION.grafana.net
#               or the same host with a "/tempo" suffix
#                   https://tempo-prod-XX-prod-REGION.grafana.net/tempo
#               Use whichever makes "${ADDRESS}/api/search" a valid endpoint — the
#               `tempo-query.sh tags` smoke test confirms it. This is the Tempo query
#               host, NOT the otlp-gateway push endpoint the collector writes to.
#   *_API_USER  The numeric instance / user ID shown next to that URL.
#   *_API_KEY   An Access Policy token scoped to `traces:read`
#               (Grafana Cloud Account -> Access Policies -> create a token; add the
#               `traces:read` scope for the relevant stack, nothing else).
#
# Optional:
#   *_TENANT_ID  X-Scope-OrgID header value — self-hosted Tempo only. Leave unset for
#               Grafana Cloud (the basic-auth user carries tenancy).

# --- Staging (primary target) ---
export TEMPO_STAGING_ADDRESS="https://tempo-prod-XX-prod-REGION.grafana.net"
export TEMPO_STAGING_API_USER="123456"
export TEMPO_STAGING_API_KEY="glc_REPLACE_WITH_A_traces_read_TOKEN"
# export TEMPO_STAGING_TENANT_ID=""

# --- Production (optional — leave commented to query staging only) ---
# export TEMPO_PROD_ADDRESS="https://tempo-prod-XX-prod-REGION.grafana.net"
# export TEMPO_PROD_API_USER="123456"
# export TEMPO_PROD_API_KEY="glc_REPLACE_WITH_A_traces_read_TOKEN"
# export TEMPO_PROD_TENANT_ID=""
