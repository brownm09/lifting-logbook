# ──────────────────────────────────────────────────────────────────────────────
# Lifting Logbook — environment variable reference
#
# Copy this file to .env.local (web) or .env (api) and fill in real values.
# Never commit .env or .env.local — both are in .gitignore.
#
# For production and staging deployments, these values live in GCP Secret Manager
# (see docs/deploy.md). The CI/CD pipeline injects them automatically.
# ──────────────────────────────────────────────────────────────────────────────


# ── Authentication (Clerk) ────────────────────────────────────────────────────
# Sign up at https://clerk.com (free tier).
# Create two apps: "lifting-logbook-dev" (dev/staging) and "lifting-logbook" (prod).
# Both keys are found in the Clerk dashboard → API Keys.

# API (apps/api/.env)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web (apps/web/.env.local)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Database ──────────────────────────────────────────────────────────────────
# For local development: run `docker compose up db` (see docker-compose.yml)
# For production/staging: Cloud SQL connection string injected by CI/CD.
#
# Two connection strings are required when using the adapter dispatch system (ADR-003):
#   DATABASE_URL         — user data store (workouts, programs, etc.)
#   SYSTEM_DATABASE_URL  — routing table (user_data_source)
#
# For simple local dev with a single Postgres instance, both can point to the same DB.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifting_logbook
SYSTEM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifting_logbook


# ── API server (apps/api) ─────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed CORS origins.
# Defaults to localhost:3001 in development.
CORS_ORIGINS=http://localhost:3001


# ── Web frontend (apps/web) ───────────────────────────────────────────────────
# Points to the local NestJS API in development.
# In GKE: set to the cluster-internal API service URL.
# In Cloud Run: set to the Cloud Run API service URL.
API_URL=http://localhost:3000

# Default training program loaded for new users.
NEXT_PUBLIC_DEFAULT_PROGRAM=5-3-1


# ── GCP (only needed when running infra scripts locally) ──────────────────────
GCP_PROJECT_ID=lifting-logbook-staging
GCP_REGION=us-central1

# Cloud KMS key name for credential encryption at rest (ADR-014).
# Set automatically by CI/CD from Terraform output.
KMS_KEY_NAME=projects/<project>/locations/us-central1/keyRings/<keyring>/cryptoKeys/user-data-source-kek
