{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false
    },
    "lint": {
      "inputs": ["src/**", "*.ts", ".eslintrc*", "eslint.config*"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
