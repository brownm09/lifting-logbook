{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "target": "es5",
    "lib": ["es2015"],
    "module": "commonjs",
    "typeRoots": ["./node_modules/@types"],
    "types": ["google-apps-script", "jest", "node"],
    "esModuleInterop": true,
    "noEmitOnError": true,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "legacy"]
}
