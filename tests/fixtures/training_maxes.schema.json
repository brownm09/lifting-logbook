{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TrainingMax",
  "type": "object",
  "properties": {
    "dateUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date in YYYY-MM-DD format (UTC)"
    },
    "lift": {
      "type": "string",
      "description": "Name of the lift"
    },
    "weight": {
      "type": "number",
      "description": "Training max weight for the lift"
    }
  },
  "required": ["dateUpdated", "lift", "weight"],
  "additionalProperties": true
}
